{
  "name": "@d-form/agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@d-form/shared": "workspace:*"
  },
  "peerDependencies": {
    "@ai-chat/vue": ">=0.0.1",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@d-form/element-plus": "workspace:*",
    "@d-form/shared": "workspace:*",
    "@vitest/coverage-v8": "^1.6.1",
    "vitest": "^1.6.1",
    "zod": "^4.3.6"
  }
}
